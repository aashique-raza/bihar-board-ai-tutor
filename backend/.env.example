PORT=5000
NODE_ENV=development

# LangChain Google embeddings use GOOGLE_API_KEY.
# GEMINI_API_KEY is supported as fallback by this project.
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here_optional_fallback

# RAG answer generation LLM provider.
# Supported values: groq, openai, google
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here_optional
