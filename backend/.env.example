PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/bihar_board_ai_tutor?retryWrites=true&w=majority&appName=Cluster0


NODE_ENV=development
GEMINI_API_KEY=


LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0

GROQ_API_KEY=
# GROQ_API_KEY=
OPENAI_API_KEY=...
GOOGLE_API_KEY=...



# Auth — JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Auth — Redis
REDIS_URL=rediss://default:your_upstash_token@your_upstash_endpoint:6379

# Auth — Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Auth — Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email_here
EMAIL_PASS=your_email_app_password_here
EMAIL_FROM=Zuno <noreply@zuno.com>

# Auth — Frontend URL
FRONTEND_URL=http://localhost:5173

# Auth — Query Limits
GUEST_DAILY_LIMIT=5
USER_DAILY_LIMIT=20

# Auth — Bcrypt
BCRYPT_SALT_ROUNDS=12
