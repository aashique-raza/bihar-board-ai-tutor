PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/bihar_board_ai_tutor?retryWrites=true&w=majority&appName=Cluster0


NODE_ENV=development
GEMINI_API_KEY=


LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0

GROQ_API_KEY=
# GROQ_API_KEY=
OPENAI_API_KEY=...
GOOGLE_API_KEY=...



# Auth — JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Auth — Redis
REDIS_URL=rediss://default:your_upstash_token@your_upstash_endpoint:6379

# Auth — Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Auth — Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email_here
EMAIL_PASS=your_email_app_password_here
EMAIL_FROM=Zuno <noreply@zuno.com>

# Auth — Frontend URL
FRONTEND_URL=http://localhost:5173

# Auth — Query Limits
GUEST_DAILY_LIMIT=5
USER_DAILY_LIMIT=20

# Session token limit — session locks when totalTokensUsed reaches this value
SESSION_TOKEN_LIMIT=15000

# Auth — Bcrypt
BCRYPT_SALT_ROUNDS=12



Tumhare Liye — Port Occupied Problem Fix Karne Ka Tarika
Jab bhi EADDRINUSE: port already in use error aaye, ye do commands chalao:

Step 1 — Kaun sa process port use kar raha hai dekho:

Get-NetTCPConnection -LocalPort 5001 -State Listen
Output mein OwningProcess column mein PID milega.

Step 2 — Us process ko kill karo:

Stop-Process -Id <PID> -Force
Ya dono ek saath (shortcut):

Get-NetTCPConnection -LocalPort 5001 -State Listen | Select-Object -ExpandProperty OwningProcess | ForEach-Object { Stop-Process -Id $_ -Force }
Port number badlo agar koi aur port pe problem ho (5001 ki jagah 5173, 3000, etc.).