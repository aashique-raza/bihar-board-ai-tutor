{
  "name": "bihar-board-ai-tutor-backend",
  "version": "0.1.0",
  "description": "Minimal backend foundation for the Bihar Board Class 10 Science AI Tutor.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test:loader": "node src/inspectors/testMarkdownLoader.js",
    "inspect:loader": "node src/inspectors/inspectMarkdownLoader.js",
    "test:chunks": "node src/inspectors/testMarkdownChunker.js",
    "inspect:chunks": "node src/inspectors/inspectMarkdownChunks.js",
    "rag:index": "node src/rag/indexPipeline.js",
    "db:ping": "node scripts/test-mongo-connection.js",
    "test:chat-db-models": "node scripts/test-chat-db-models.js",
    "test:ask-db": "node scripts/test-ask-db-integration.js",
    "curriculum:build": "node scripts/build-curriculum-index.js",
    "test:curriculum-resolvers": "node scripts/test-curriculum-resolvers.js",
    "rag:test-retriever": "node scripts/test-retriever.js",
    "rag:test-answer": "node scripts/test-rag-answer.js",
    "test:study-map": "node scripts/test-study-map.js",
    "test:embedding-smoke": "node scripts/test-langchain-embedding-smoke.js",
    "test:vector-store": "node scripts/validate-vector-store.js",
    "test:retrieval": "node scripts/test-vector-store-load-search.js",
    "test:golden": "node scripts/run-golden-set.js",
    "test:golden-save": "node scripts/run-golden-set.js --save-baseline"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@langchain/classic": "1.0.32",
    "@langchain/core": "^1.1.46",
    "@langchain/google-genai": "^2.1.30",
    "@langchain/groq": "^1.2.0",
    "@langchain/openai": "^1.4.5",
    "@langchain/textsplitters": "^1.0.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "gray-matter": "^4.0.3",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.10",
    "rate-limit-redis": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
